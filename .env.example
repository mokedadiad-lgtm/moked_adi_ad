# --- פרודקשן: ראה DEPLOY.md להעלאה ולמשתני סביבה ---

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# שליחת תשובה למייל השואל (עריכה לשונית → שלח וארכב)
RESEND_API_KEY=re_xxxx
# אופציונלי: כתובת השולח (ברירת מחדל: onboarding@resend.dev)
# RESEND_FROM_EMAIL=מערכת <noreply@yourdomain.com>

# קישורים במיילים (שיבוץ משיב, לובי, איפוס סיסמה) – בפרודקשן חובה!
# דוגמה: https://your-app.vercel.app או https://yourdomain.co.il
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Cron: תזכורת 5 ימים + סיכום לובי יומי (Vercel Cron שולח Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=your-random-secret

# Green-API (שליחת הודעות וואטסאפ)
# GREEN_API_ID_INSTANCE=110100001
# GREEN_API_TOKEN_INSTANCE=your-token-from-green-api-console

# Meta WhatsApp Cloud API (שליחה + webhook)
# אימות webhook (GET/POST)
# WHATSAPP_VERIFY_TOKEN=your-verify-token
# META_APP_SECRET=your-meta-app-secret
#
# שליחת הודעות דרך Graph API
# META_ACCESS_TOKEN=your-graph-access-token
# META_PHONE_NUMBER_ID=your-phone-number-id
# (אופציונלי) META_GRAPH_API_VERSION=v20.0
