# --- פרודקשן: ראה DEPLOY.md להעלאה ולמשתני סביבה ---

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# שליחת תשובה למייל השואל (עריכה לשונית → שלח וארכב)
RESEND_API_KEY=re_xxxx
# אופציונלי: כתובת השולח (ברירת מחדל: onboarding@resend.dev)
# RESEND_FROM_EMAIL=מערכת <noreply@yourdomain.com>

# קישורים במיילים (שיבוץ משיב, לובי, איפוס סיסמה) – בפרודקשן חובה!
# דוגמה: https://your-app.vercel.app או https://yourdomain.co.il
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Cron: תזכורת 5 ימים + סיכום לובי יומי (Vercel Cron שולח Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=your-random-secret

# Green-API (שליחת הודעות וואטסאפ)
# GREEN_API_ID_INSTANCE=110100001
# GREEN_API_TOKEN_INSTANCE=your-token-from-green-api-console

# Meta WhatsApp Cloud API (שליחה + webhook)
# אימות webhook (GET/POST)
# WHATSAPP_VERIFY_TOKEN=askmeplus123
# META_APP_SECRET=cd3b1d8062bd2c0f538abb9d080767ac
#
# שליחת הודעות דרך Graph API
# META_ACCESS_TOKEN=EAAlRhv3t7A4BQ5NMQx4EneXrSaaPPZBnloQP1NxOuij07mtDWu8Uy9rXTOPCul9pAQVd7SAI1PZA8AzPx0xYNs3wXRV2FZCXN6E29QVxksuWNZC2SHnW8v9nFXZBDgBpeY3gEZAX1UXIvGkLge5qeO4RWUpZBWGFjUTfoIcbZA4BnQQaQc941VzIcW3ZAyjGeZCRexHgZDZD
# META_PHONE_NUMBER_ID=997143003488419
# (אופציונלי) META_GRAPH_API_VERSION=v25.0
#
# תבניות Meta להודעות יזומות (אופציונלי). כשלא מוגדר — נשלח טקסט חופשי.
# ראה טבלת גופי תבנית ב-DEPLOY.md; שמות התבניות חייבים להתאים לאישור ב-WhatsApp Manager.
# WHATSAPP_TEMPLATE_LANGUAGE=he
# WHATSAPP_TEMPLATE_LOBBY_NEW_QUESTION=
# WHATSAPP_TEMPLATE_LINGUISTIC_NEW_QUESTION=
# WHATSAPP_TEMPLATE_RESPONDENT_ASSIGNMENT=
# WHATSAPP_TEMPLATE_ASKER_PDF_SENT=
# WHATSAPP_TEMPLATE_CRON_LOBBY_SUMMARY=
# WHATSAPP_TEMPLATE_CRON_INACTIVITY_REMINDER=

# --- Web Push (VAPID) — התראות דחיפה לאדמין על דואר נכנס WhatsApp ---
# קל להעתקה: npm run save-vapid-keys  →  נוצר vapid-keys.txt (נפתח בעורך, לא בגיט)
# או בטרמינל: npx web-push generate-vapid-keys
#   Public Key  → שורה 1 למטה (NEXT_PUBLIC_…)
#   Private Key → שורה 2 למטה (VAPID_PRIVATE_KEY)
#   VAPID_SUBJECT — כתובת mailto אמיתית (חובה לפרוטוקול; לא נשלח מייל אוטומטי)
#
# העתק ל־.env.local (מקומי) ול־Vercel → Environment Variables (אותם שלושה שמות):
#
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=הדבק_כאן_את_כל_שורת_ה-Public_Key_בלי_רווחים_באמצע
# VAPID_PRIVATE_KEY=הדבק_כאן_את_כל_שורת_ה-Private_Key_בלי_רווחים_באמצע
# VAPID_SUBJECT=mailto:you@example.com
